#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
      zmk,physical-layout = &dax3_physical_layout;
    };

    dax3_physical_layout: dax3_physical_layout {
      compatible = "zmk,physical-layout";
      display-name = "Default";
      transform = <&default_transform>;
      kscan = <&kscan0>;

      keys //                    w   h    x    y  rot rx ry
        // Row 0
        = <&key_physical_attrs 100 100    0    0   0  0  0>  //  0: Row0-Col0
        , <&key_physical_attrs 100 100  100    0   0  0  0>  //  1: Row0-Col1
        , <&key_physical_attrs 100 100  200    0   0  0  0>  //  2: Row0-Col2
        , <&key_physical_attrs 100 100  300    0   0  0  0>  //  3: Row0-Col3
        , <&key_physical_attrs 100 100  400    0   0  0  0>  //  4: Row0-Col4
        , <&key_physical_attrs 100 100  500    0   0  0  0>  //  5: Row0-Col5
        , <&key_physical_attrs 100 100 1000    0   0  0  0>  //  6: Row0-Col8
        , <&key_physical_attrs 100 100 1100    0   0  0  0>  //  7: Row0-Col9
        , <&key_physical_attrs 100 100 1200    0   0  0  0>  //  8: Row0-Col10
        , <&key_physical_attrs 100 100 1300    0   0  0  0>  //  9: Row0-Col11
        , <&key_physical_attrs 100 100 1400    0   0  0  0>  // 10: Row0-Col12
        , <&key_physical_attrs 100 100 1500    0   0  0  0>  // 11: Row0-Col13
        // Row 1
        , <&key_physical_attrs 100 100    0  100   0  0  0>  // 12: Row1-Col0
        , <&key_physical_attrs 100 100  100  100   0  0  0>  // 13: Row1-Col1
        , <&key_physical_attrs 100 100  200  100   0  0  0>  // 14: Row1-Col2
        , <&key_physical_attrs 100 100  300  100   0  0  0>  // 15: Row1-Col3
        , <&key_physical_attrs 100 100  400  100   0  0  0>  // 16: Row1-Col4
        , <&key_physical_attrs 100 100  500  100   0  0  0>  // 17: Row1-Col5
        , <&key_physical_attrs 100 100 1000  100   0  0  0>  // 18: Row1-Col8
        , <&key_physical_attrs 100 100 1100  100   0  0  0>  // 19: Row1-Col9
        , <&key_physical_attrs 100 100 1200  100   0  0  0>  // 20: Row1-Col10
        , <&key_physical_attrs 100 100 1300  100   0  0  0>  // 21: Row1-Col11
        , <&key_physical_attrs 100 100 1400  100   0  0  0>  // 22: Row1-Col12
        , <&key_physical_attrs 100 100 1500  100   0  0  0>  // 23: Row1-Col13
        // Row 2
        , <&key_physical_attrs 100 100    0  200   0  0  0>  // 24: Row2-Col0
        , <&key_physical_attrs 100 100  100  200   0  0  0>  // 25: Row2-Col1
        , <&key_physical_attrs 100 100  200  200   0  0  0>  // 26: Row2-Col2
        , <&key_physical_attrs 100 100  300  200   0  0  0>  // 27: Row2-Col3
        , <&key_physical_attrs 100 100  400  200   0  0  0>  // 28: Row2-Col4
        , <&key_physical_attrs 100 100  500  200   0  0  0>  // 29: Row2-Col5
        , <&key_physical_attrs 100 100  600  150   0  0  0>  // 30: Row2-Col6
        , <&key_physical_attrs 100 100  900  150   0  0  0>  // 31: Row2-Col7
        , <&key_physical_attrs 100 100 1000  200   0  0  0>  // 32: Row2-Col8
        , <&key_physical_attrs 100 100 1100  200   0  0  0>  // 33: Row2-Col9
        , <&key_physical_attrs 100 100 1200  200   0  0  0>  // 34: Row2-Col10
        , <&key_physical_attrs 100 100 1300  200   0  0  0>  // 35: Row2-Col11
        , <&key_physical_attrs 100 100 1400  200   0  0  0>  // 36: Row2-Col12
        , <&key_physical_attrs 100 100 1500  200   0  0  0>  // 37: Row2-Col13
        // Row 3
        , <&key_physical_attrs 100 100  200  300   0  0  0>  // 38: Row3-Col2
        , <&key_physical_attrs 100 100  300  300   0  0  0>  // 39: Row3-Col3
        , <&key_physical_attrs 100 100  450  300   0  0  0>  // 40: Row3-Col4
        , <&key_physical_attrs 100 100  550  300   0  0  0>  // 41: Row3-Col5
        , <&key_physical_attrs 100 100  650  300   0  0  0>  // 42: Row3-Col6
        , <&key_physical_attrs 100 100  850  300   0  0  0>  // 43: Row3-Col7
        , <&key_physical_attrs 100 100  950  300   0  0  0>  // 44: Row3-Col8
        , <&key_physical_attrs 100 100 1200  300   0  0  0>  // 45: Row3-Col11
        ;
    };

    default_transform: keymap_transform_0 {
      compatible = "zmk,matrix-transform";
      columns = <14>;
      rows = <4>;
      map = <
        RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                    RC(0,8) RC(0,9) RC(0,10) RC(0,11) RC(0,12) RC(0,13)
        RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)                    RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13)
        RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6)    RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12) RC(2,13)
                        RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6)    RC(3,7) RC(3,8)                  RC(3,11)
      >;
    };

    kscan0: kscan {
      compatible = "zmk,kscan-gpio-matrix";
      label = "KSCAN";
      diode-direction = "col2row";
      row-gpios
        = <&xiao_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // D0/P0.02 -> Row0
        , <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // D1/P0.03 -> Row1
        , <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // D2/P0.28 -> Row2
        , <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // D3/P0.29 -> Row3
        ;
    };

    left_encoder: encoder_left {
      compatible = "alps,ec11";
      steps = <80>;
      status = "disabled";
    };

    right_encoder: encoder_right {
      compatible = "alps,ec11";
      steps = <80>;
      status = "disabled";
    };

    sensors: sensors {
      compatible = "zmk,keymap-sensors";
      sensors = <&left_encoder &right_encoder>;
      triggers-per-rotation = <30>;
    };
};
